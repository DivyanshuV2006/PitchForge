<?xml version="1.0" encoding="utf-8"?>
<!--
  PitchForge launcher foreground — original vector artwork (royalty-free).
  Motif: a clean tuning fork (absolute pitch) with a soft forge glow + spark.
  Drawn for the adaptive-icon safe zone (inner ~66% of the 108dp canvas).
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Soft amber forge glow -->
    <path
        android:fillColor="#33FFB300"
        android:pathData="M54,54m-26,0a26,26 0,1 1,52 0a26,26 0,1 1,-52 0"/>

    <!-- Left tine -->
    <path
        android:fillColor="#FFB300"
        android:pathData="M41,28h7v32h-7z"/>

    <!-- Right tine -->
    <path
        android:fillColor="#FFB300"
        android:pathData="M60,28h7v32h-7z"/>

    <!-- Crossbar / yoke joining the tines -->
    <path
        android:fillColor="#FFB300"
        android:pathData="M41,56h26v10h-26z"/>

    <!-- Stem -->
    <path
        android:fillColor="#FFB300"
        android:pathData="M50,66h8v18h-8z"/>

    <!-- Forged foot -->
    <path
        android:fillColor="#FFE082"
        android:pathData="M46,84h16v5h-16z"/>

    <!-- Forge spark -->
    <path
        android:fillColor="#FFE082"
        android:pathData="M73,33
            l1.3,3
            l3,1.3
            l-3,1.3
            l-1.3,3
            l-1.3,-3
            l-3,-1.3
            l3,-1.3
            z"/>
</vector>
